# ENVIRONMENT VARIABLES BLANK ARCHITECTURE TEMPLATE

# System Operational Flags
ENV=production
PROJECT_NAME="AI Resume Matcher"
MAX_FILE_SIZE_MB=5

# Dynamic Infrastructure Connections (Default hostnames route over Docker Network Mesh)
MONGO_URI=mongodb://production_mongodb_datastore:27017
MONGO_DB_NAME=resume_analyzer
REDIS_URL=redis://production_redis_broker:6379
QUEUE_NAME=resume_analyzer_jobs

# Dynamic Allowed Client Origins for Security Handshakes (Comma-Separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Provider Access Authentication Keys
# Generate OpenAI keys at: https://openai.com
# Generate Google Gemini keys at: https://google.com
OPENAI_API_KEY=your_sk_proj_openai_api_credential_key_here
GEMINI_API_KEY=your_AIzaSy_google_gemini_api_key_here
